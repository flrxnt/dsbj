{
  "name": "@flrxnt/dsbj",
  "version": "1.3.3",
  "description": "Design Système du Bénin - Système de design gouvernemental de la République du Bénin",
  "author": "République du Bénin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flrxnt/dsbj"
  },
  "bugs": {
    "url": "https://github.com/flrxnt/dsbj/issues"
  },
  "homepage": "https://github.com/flrxnt/dsbj#readme",
  "type": "module",
  "main": "dist/dsbj.umd.js",
  "module": "dist/dsbj.es.js",
  "types": "dist/index.d.ts",
  "style": "dist/dsbj.css",
  "exports": {
    ".": {
      "import": "./dist/dsbj.es.js",
      "require": "./dist/dsbj.umd.js",
      "types": "./dist/index.d.ts",
      "style": "./dist/dsbj.css"
    },
    "./vue": {
      "import": "./src/vue/index.ts",
      "types": "./src/vue/index.ts"
    },
    "./react": {
      "import": "./src/react/index.ts",
      "types": "./src/react/index.ts"
    },
    "./css": "./dist/dsbj.css",
    "./reset": "./dist/dsbj-reset.css",
    "./scss": "./src/dsbj.scss",
    "./scss/reset": "./src/dsbj-reset.scss"
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "src/index.ts",
    "src/js/*.ts"
  ],
  "workspaces": [
    "mcp"
  ],
  "scripts": {
    "dev": "vite --config vite.docs.config.ts",
    "build": "vite build && bun run build:reset",
    "build:reset": "bunx sass-embedded src/dsbj-reset.scss dist/dsbj-reset.css --style=compressed --no-source-map",
    "pwa:icons": "bun scripts/generate-pwa-icons.ts",
    "build:docs": "bun scripts/build-docs.ts",
    "preview": "vite preview --config vite.preview.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:prepare": "bun scripts/release.ts",
    "release": "bun run test && bun run build && git push && git push --tags",
    "mcp:start": "bun run --cwd mcp start",
    "mcp:dev": "bun run --cwd mcp dev"
  },
  "devDependencies": {
    "vite": "latest",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "latest",
    "typescript": "latest",
    "sass-embedded": "latest",
    "sharp": "^0.34.5",
    "jsdom": "latest"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@unhead/vue": "^2.1.12",
    "@vitejs/plugin-vue": "^6.0.5",
    "shiki": "^4.0.2",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "workbox-window": "^7.4.0"
  }
}
